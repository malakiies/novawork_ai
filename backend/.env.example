# =============================================
# NovaWork AI — Variables d'environnement
# =============================================
# ⚠️  NE JAMAIS COMMITTER CE FICHIER !
# Ajouter .env dans .gitignore immédiatement.

# ─── Serveur ─────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB Atlas ───────────────────────────
# ⚠️  CHANGEZ VOTRE MOT DE PASSE DANS MONGODB ATLAS
# Puis remplacez <NEW_PASSWORD> par votre nouveau mot de passe
mongodb+srv://entreprenariat:malak12345@angel-ecommerce.uiqiwnt.mongodb.net/?appName=angel-ecommerce
# ─── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=novawork_access_secret_change_this_in_production
JWT_REFRESH_SECRET=novawork_refresh_secret_change_this_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cloudinary ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=novawork

# ─── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ─── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@novawork.ai
EMAIL_FROM_NAME=NovaWork AI

# ─── Bcrypt ───────────────────────────────────
BCRYPT_SALT_ROUNDS=12
